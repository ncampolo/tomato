# Import volume: lbs per truck 
# fread won't parse this file cleanly due to its irregular header structure
# Read raw lines instead and extract the Grand Total row directly
import_lines <- readLines("/Users/nickcampolo/Desktop/tomato_import_volume.csv")
grand_total_line <- import_lines[grep("Grand Total", import_lines)]

# Split and clean the values
gt_values <- strsplit(grand_total_line, ",")[[1]]
gt_values <- gsub('"', '', gt_values)   # remove quotes
gt_values <- trimws(gt_values)

# Years 2008-2022 are in positions 7-21 (1-indexed)
total_mt_by_year <- data.frame(
  year     = 2008:2022,
  total_mt = as.numeric(gt_values[7:21])
)

# Convert to lbs, apply Nogales share
nogales_share <- 0.28

# Annual truck counts for 2008-2022
annual_truck_counts <- nogales_trucks %>%
  mutate(year = lubridate::year(month_date)) %>%
  filter(year %in% 2008:2022) %>%
  group_by(year) %>%
  summarise(annual_trucks = sum(trucks_per_week, na.rm = TRUE), .groups = "drop")

# Lbs per truck by year, then average
lbs_per_truck_by_year <- total_mt_by_year %>%
  left_join(annual_truck_counts, by = "year") %>%
  mutate(
    total_lbs     = total_mt * 2204.62,
    nogales_lbs   = total_lbs * nogales_share,
    lbs_per_truck = nogales_lbs / annual_trucks
  )

avg_lbs_per_truck <- mean(lbs_per_truck_by_year$lbs_per_truck, na.rm = TRUE)
avg_annual_trucks <- mean(lbs_per_truck_by_year$annual_trucks, na.rm = TRUE)

cat("Average lbs per truck:", round(avg_lbs_per_truck, 0), "\n")

# Marginal cost table
# Use percentiles of abs_max_wait_nogales as the duration rows
# (from weekly_costs, one row per week)
wait_percentiles <- quantile(
  weekly_costs$abs_max_wait_nogales,
  probs = c(0.50, 0.75, 0.90, 1.00),
  na.rm = TRUE
)

cat("Wait time percentiles (minutes):\n")
print(round(wait_percentiles, 1))

durations <- as.numeric(wait_percentiles)
duration_labels <- c("Mean", "75th percentile", "90th percentile", "Maximum")

# Use mean for the "mean" row instead of median
durations[1] <- mean(weekly_costs$abs_max_wait_nogales, na.rm = TRUE)

avg_cost_per_min    <- mean(total_cost_per_min, na.rm = TRUE)
cost_per_min_per_lb <- avg_cost_per_min / avg_lbs_per_truck
cost_per_min_all    <- avg_cost_per_min * avg_annual_trucks

marginal_table <- data.frame(
  duration   = duration_labels,
  minutes    = round(durations, 1),
  per_lb     = durations * cost_per_min_per_lb,
  per_truck  = durations * avg_cost_per_min,
  all_trucks = durations * cost_per_min_all
) %>%
  mutate(
    per_lb     = round(per_lb, 5),
    per_truck  = round(per_truck, 2),
    all_trucks = scales::dollar(round(all_trucks, 0))
  )

marginal_table %>%
  kable(
    format    = "latex",
    booktabs  = TRUE,
    col.names = c("Max wait time", "Minutes", "Cost per lb",
                  "Per truck", "All trucks"),
    caption   = "Marginal Cost Due to Idling Wait Times",
    label     = "tab:marginal_cost",
    escape    = FALSE
  ) %>%
  kable_styling(latex_options = c("hold_position"))


